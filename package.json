{
  "name": "@borsapi/mcp-server",
  "version": "1.0.1",
  "description": "MCP server for B\u00f6rsAPI \u2014 query Swedish financial data from AI tools like Cursor and Claude Desktop",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "borsapi-mcp-server": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/add-shebang.mjs",
    "start": "node dist/index.js",
    "test": "tsx --test __tests__/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "borsapi",
    "financial-data",
    "sweden",
    "model-context-protocol"
  ],
  "author": "B\u00f6rsAPI AB",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sibb74/borsapi.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
